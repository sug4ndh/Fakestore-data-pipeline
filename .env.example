# Copy this file to .env and fill in the values.
# .env will be git-ignored.

# Required: HMAC-SHA256 secret key for PII pseudonymisation.
# Must be the same key on every run, changing it invalidates all
# previously hashed identifiers and breaks joins across pipeline runs.
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
PIPELINE_SECRET_KEY=replace-with-a-strong-secret-key

# Optional: override the run date (ISO format YYYY-MM-DD).
# Defaults to today if not set.
# For local backfill: RUN_DATE=2026-03-17 docker compose up
RUN_DATE=
